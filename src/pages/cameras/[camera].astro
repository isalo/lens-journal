---
import type { GetStaticPaths } from 'astro';
import { getCameraGroups } from '@lib/entries';
import BaseLayout from '@layouts/BaseLayout.astro';
import PageIntro from '@components/ui/PageIntro.astro';
import EntryCard from '@components/EntryCard.astro';

export const getStaticPaths = (async () => {
  const groups = await getCameraGroups();
  return groups.map((group) => ({
    params: { camera: group.slug },
    props: { group },
  }));
}) satisfies GetStaticPaths;

const { group } = Astro.props;
---

<BaseLayout
  title={group.label}
  description={`Photographs captured with the ${group.label}.`}
>
  <p class="mb-2"><a href="/cameras" class="link-underline text-sm text-ink-muted dark:text-paper-soft/60">&larr; All cameras</a></p>
  <PageIntro
    title={group.label}
    description="Every journal entry photographed with this camera."
    count={group.count}
    countLabel="photos"
  />

  <div class="grid grid-cols-1 gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
    {group.entries.map((resolved) => (
      <EntryCard resolved={resolved} />
    ))}
  </div>
</BaseLayout>

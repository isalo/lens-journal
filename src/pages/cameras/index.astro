---
import { getCameraGroups } from '@lib/entries';
import BaseLayout from '@layouts/BaseLayout.astro';
import PageIntro from '@components/ui/PageIntro.astro';
import GearCard from '@components/GearCard.astro';

const groups = await getCameraGroups();
---

<BaseLayout
  title="Cameras"
  description="Photographs grouped by the camera body that captured them."
>
  <PageIntro
    title="Cameras"
    description="Browse the journal by camera body, detected automatically from EXIF metadata."
    count={groups.length}
    countLabel="cameras"
  />

  {groups.length > 0 ? (
    <div class="grid grid-cols-1 gap-x-8 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
      {groups.map((group) => (
        <GearCard group={group} basePath="/cameras" />
      ))}
    </div>
  ) : (
    <p class="text-ink-muted dark:text-paper-soft/60">No camera metadata found yet.</p>
  )}
</BaseLayout>

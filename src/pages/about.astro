---
import { SITE } from '@/consts';
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="About" description={`About ${SITE.title}`}>
  <div class="container-prose">
    <h1 class="font-serif text-4xl tracking-tightest sm:text-5xl">About</h1>
    <div class="prose prose-lg mt-8 dark:prose-invert">
      <p>
        <strong>{SITE.title}</strong> is a minimalist photo journal powered by MDX.
        It blends photography, storytelling, location and camera metadata into a
        beautiful, fast static website.
      </p>
      <p>
        Every entry is a plain MDX file with a photograph attached. The build
        pipeline extracts EXIF data &mdash; camera, lens, focal length, aperture,
        shutter speed, ISO and GPS &mdash; and turns it into rich, browsable pages.
      </p>
      <h2>Principles</h2>
      <ul>
        <li><strong>Local-first &amp; markdown-first</strong> &mdash; your words and photos live as files you own.</li>
        <li><strong>Zero database</strong> &mdash; everything is resolved at build time.</li>
        <li><strong>Privacy friendly</strong> &mdash; no trackers, no backend, no analytics by default.</li>
        <li><strong>Beautiful &amp; fast</strong> &mdash; elegant typography and optimized images.</li>
      </ul>
      <h2>Write a new entry</h2>
      <p>Create a folder under <code>src/content/entries/</code> with an <code>index.mdx</code>:</p>
      <pre><code>---
title: Morning in Warsaw
date: 2026-05-21
photo: warsaw.jpg
location: Warsaw, Poland
tags: [travel, city]
---

Today I walked through the old town...</code></pre>
      <p>
        Drop the matching photograph into <code>src/assets/photos/</code>. The camera,
        lens and location pages populate themselves automatically.
      </p>
    </div>
  </div>
</BaseLayout>

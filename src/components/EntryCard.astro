---
import type { ResolvedEntry } from '@types';
import { formatDate } from '@lib/format';
import PhotoFrame from '@components/photo/PhotoFrame.astro';
import ExifBadge from '@components/photo/ExifBadge.astro';

interface Props {
  resolved: ResolvedEntry;
  /** First item on the timeline loads eagerly for a fast LCP. */
  eager?: boolean;
}

const { resolved, eager = false } = Astro.props;
const { entry, photo, slug } = resolved;
const { title, date, summary, location } = entry.data;
const href = `/entries/${slug}`;
---

<article class="group animate-fade-up">
  <a href={href} class="block">
    <div class="relative overflow-hidden rounded-2xl">
      <PhotoFrame
        photo={photo}
        alt={title}
        ratio="aspect-[3/2]"
        loading={eager ? 'eager' : 'lazy'}
        class="transition-transform duration-700 ease-out group-hover:scale-[1.03]"
      />
      {photo && (
        <div class="pointer-events-none absolute inset-x-0 bottom-0 flex justify-end p-3 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
          <ExifBadge exif={photo.exif} />
        </div>
      )}
    </div>
  </a>

  <div class="mt-4 flex items-baseline justify-between gap-4">
    <time datetime={date.toISOString()} class="meta-label">{formatDate(date)}</time>
    {location && (
      <span class="meta-label truncate" title={location}>{location}</span>
    )}
  </div>
  <h3 class="mt-1.5 font-serif text-xl leading-snug tracking-tight">
    <a href={href} class="link-underline">{title}</a>
  </h3>
  {summary && (
    <p class="mt-1.5 line-clamp-2 text-sm leading-relaxed text-ink-muted dark:text-paper-soft/60">
      {summary}
    </p>
  )}
</article>

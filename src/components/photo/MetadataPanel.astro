---
import type { PhotoExif } from '@types';
import {
  formatAperture,
  formatShutter,
  formatFocalLength,
  formatIso,
  formatDate,
} from '@lib/format';

interface Props {
  exif: PhotoExif;
  /** Effective camera/lens/location (frontmatter overrides applied upstream). */
  camera?: string;
  lens?: string;
  location?: string;
}

const { exif, camera, lens, location } = Astro.props;

const rows: { label: string; value: string | undefined }[] = [
  { label: 'Camera', value: camera ?? exif.camera },
  { label: 'Lens', value: lens ?? exif.lens },
  { label: 'Focal length', value: formatFocalLength(exif.focalLength) },
  { label: 'Aperture', value: formatAperture(exif.aperture) },
  { label: 'Shutter', value: formatShutter(exif.shutterSpeed) },
  { label: 'ISO', value: formatIso(exif.iso) },
  { label: 'Captured', value: exif.capturedAt ? formatDate(exif.capturedAt) : undefined },
  { label: 'Location', value: location },
];

const visible = rows.filter((r) => r.value);
---

{visible.length > 0 && (
  <aside class="rounded-2xl border border-ink/8 bg-paper-soft/60 p-6 dark:border-paper/10 dark:bg-night-panel/60">
    <h2 class="meta-label mb-4">Shot details</h2>
    <dl class="grid grid-cols-2 gap-x-6 gap-y-4">
      {visible.map((row) => (
        <div class="min-w-0">
          <dt class="meta-label">{row.label}</dt>
          <dd class="mt-0.5 truncate font-mono text-sm text-ink dark:text-paper" title={row.value}>
            {row.value}
          </dd>
        </div>
      ))}
    </dl>
  </aside>
)}

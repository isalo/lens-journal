---
import type { PhotoExif } from '@types';
import { exposureSummary } from '@lib/format';

interface Props {
  exif: PhotoExif;
  class?: string;
}

const { exif, class: className } = Astro.props;
const summary = exposureSummary(exif);
---

{summary && (
  <span
    class:list={[
      'inline-flex items-center gap-1.5 rounded-full border border-ink/10 bg-paper/70 px-3 py-1 font-mono text-xs text-ink-soft backdrop-blur dark:border-paper/15 dark:bg-night/50 dark:text-paper-soft/80',
      className,
    ]}
  >
    {summary}
  </span>
)}

---
import { getLensGroups, withBase } from '@lib/journal';
import BaseLayout from '@layouts/BaseLayout.astro';
import PageIntro from '@components/ui/PageIntro.astro';
import EntryCard from '@components/EntryCard.astro';

export async function getStaticPaths() {
  const groups = await getLensGroups();
  return groups.map((group) => ({
    params: { lens: group.slug },
    props: { group },
  }));
}

const { group } = Astro.props;
---

<BaseLayout
  title={group.label}
  description={`Photographs made with the ${group.label}.`}
>
  <PageIntro
    title={group.label}
    description="Photographs made with this lens."
    count={group.count}
    countLabel="entries"
  />
  <div class="grid grid-cols-1 gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
    {group.entries.map((entry) => <EntryCard entry={entry} />)}
  </div>
  <div class="mt-12 border-t border-ink/8 pt-6 dark:border-paper/10">
    <a
      href={withBase('/lenses')}
      class="link-underline text-sm text-ink-muted dark:text-paper-soft/60"
      >&larr; All lenses</a
    >
  </div>
</BaseLayout>

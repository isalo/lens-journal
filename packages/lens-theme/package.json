{
  "name": "@lens-journal/theme",
  "version": "0.1.0",
  "description": "Shared Lens Journal theme: Tailwind preset, base styles and framework-agnostic view-model helpers for the Astro photo journal.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "lens-journal",
    "astro",
    "tailwind",
    "theme",
    "photography"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lens-journal/lens-journal.git",
    "directory": "packages/lens-theme"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tailwind-preset": "./tailwind-preset.js",
    "./styles/global.css": "./styles/global.css"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "tailwind-preset.js",
    "styles"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@lens-journal/core": "workspace:*"
  },
  "peerDependencies": {
    "@tailwindcss/typography": ">=0.5",
    "tailwindcss": ">=3.4"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "^22.13.0",
    "tailwindcss": "^3.4.17"
  },
  "publishConfig": {
    "access": "public"
  }
}

---
import type { GearGroup } from '@types';

interface Props {
  group: GearGroup;
  base: 'cameras' | 'lenses';
}

const { group, base } = Astro.props;
const cover = group.entries[0]?.data.coverPhoto;
---

<a
  href={`/${base}/${group.slug}`}
  class="group flex items-center gap-4 rounded-2xl border border-ink/8 p-3 transition-colors hover:border-accent/40 dark:border-paper/10"
>
  <div class="h-16 w-16 shrink-0 overflow-hidden rounded-xl bg-night">
    {
      cover && (
        <img
          src={cover}
          alt=""
          loading="lazy"
          class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
        />
      )
    }
  </div>
  <div class="min-w-0">
    <p class="truncate font-medium text-ink dark:text-paper">{group.label}</p>
    <p class="meta-label mt-0.5">
      {group.count}
      {group.count === 1 ? 'entry' : 'entries'}
    </p>
  </div>
</a>

---
import { SITE } from '@/consts';
import { getEntries, hrefOf, locationLabel } from '@lib/journal';
import { formatDate } from '@lens-journal/core';

import BaseLayout from '@layouts/BaseLayout.astro';
import EntryCard from '@components/EntryCard.astro';
import ExifBadge from '@components/photo/ExifBadge.astro';

const entries = await getEntries();
const [featured, ...rest] = entries;
---

<BaseLayout bleed>
  <section class="container-content pt-10 sm:pt-14">
    <p class="meta-label animate-fade-in">{SITE.tagline}</p>
    <h1
      class="mt-3 max-w-3xl animate-fade-up font-serif text-4xl leading-[1.05] tracking-tightest sm:text-6xl"
    >
      A journal of light, places&nbsp;and&nbsp;moments.
    </h1>
    <p
      class="mt-4 max-w-xl animate-fade-up text-base leading-relaxed text-ink-muted dark:text-paper-soft/60"
    >
      {SITE.description}
    </p>
  </section>

  {
    featured && (
      <section class="container-content mt-10 sm:mt-14">
        <a href={hrefOf(featured)} class="group block">
          <div class="relative overflow-hidden rounded-3xl bg-night">
            {featured.data.coverPhoto ? (
              <img
                src={featured.data.coverPhoto}
                alt={featured.data.title}
                loading="eager"
                fetchpriority="high"
                class="aspect-[16/9] w-full object-cover transition-transform duration-[1.2s] ease-out group-hover:scale-105"
              />
            ) : (
              <div class="aspect-[16/9] w-full" />
            )}
            <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/5 to-transparent" />
            <div class="absolute inset-x-0 bottom-0 p-6 sm:p-10">
              <div class="flex items-center gap-3 text-white/80">
                <span class="text-xs font-medium uppercase tracking-[0.16em]">
                  Latest
                </span>
                <time class="text-sm">{formatDate(featured.data.date)}</time>
                {locationLabel(featured.data) && (
                  <span class="text-sm text-white/70">
                    &middot; {locationLabel(featured.data)}
                  </span>
                )}
              </div>
              <h2 class="mt-2 max-w-2xl font-serif text-3xl text-white sm:text-5xl sm:tracking-tightest">
                {featured.data.title}
              </h2>
              <div class="mt-4">
                <ExifBadge exif={featured.data.exif} />
              </div>
            </div>
          </div>
        </a>
      </section>
    )
  }

  <section class="container-content mt-16 sm:mt-24">
    <div class="mb-8 flex items-end justify-between">
      <h2 class="font-serif text-2xl tracking-tight">The timeline</h2>
      <span class="meta-label">{entries.length} entries</span>
    </div>

    {
      rest.length > 0 ? (
        <div class="grid grid-cols-1 gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3">
          {rest.map((entry) => (
            <EntryCard entry={entry} />
          ))}
        </div>
      ) : (
        <p class="text-ink-muted dark:text-paper-soft/60">
          No more entries yet. Import photos with{' '}
          <code class="font-mono">lens import ./photos</code>.
        </p>
      )
    }
  </section>
</BaseLayout>
